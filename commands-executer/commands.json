[
  {
    "name": "Create animal file with touch",
    "commands": [
      "touch zoo-project/animals/mammals/bear.txt"
    ]
  },
  {
    "name": "Create folder with mkdir",
    "commands": [
      "mkdir zoo-project/animals/amphibians"
    ]
  },
  {
    "name": "Move into mammals folder",
    "commands": [
      "cd zoo-project/animals/mammals"
    ]
  },
  {
    "name": "Move to parent folder",
    "commands": [
      "cd .."
    ]
  },
  {
    "name": "Move to home directory",
    "commands": [
      "cd ~"
    ]
  },
  {
    "name": "Move to previous directory",
    "commands": [
      "cd -"
    ]
  },
  {
    "name": "Move shark file to reptiles",
    "commands": [
      "mv zoo-project/animals/ocean/shark.txt zoo-project/animals/reptiles/shark.txt"
    ]
  },
  {
    "name": "Copy lion file",
    "commands": [
      "cp zoo-project/animals/mammals/lion.txt zoo-project/animals/mammals/lion-copy.txt"
    ]
  },
  {
    "name": "Find lion file",
    "commands": [
      "find zoo-project -name \"lion.txt\""
    ]
  },
  {
    "name": "Find txt files",
    "commands": [
      "find zoo-project -name \"*.txt\""
    ]
  },
  {
    "name": "Find directories",
    "commands": [
      "find zoo-project -type d"
    ]
  },
  {
    "name": "Grep lion in lion file",
    "commands": [
      "grep Lion zoo-project/animals/mammals/lion.txt"
    ]
  },
  {
    "name": "Grep penguin in txt files",
    "commands": [
      "grep penguin zoo-project/**/*.txt"
    ]
  },
  {
    "name": "Grep fish in animal files",
    "commands": [
      "grep fish zoo-project/animals/**/*.txt"
    ]
  },
  {
    "name": "Recursive grep shark",
    "commands": [
      "grep -r shark zoo-project"
    ]
  },
  {
    "name": "Recursive grep with less",
    "commands": [
      "grep -r animal zoo-project | less"
    ]
  },
  {
    "name": "Ripgrep lion in lion file",
    "commands": [
      "rg Lion zoo-project/animals/mammals/lion.txt"
    ]
  },
  {
    "name": "Ripgrep penguin in txt files",
    "commands": [
      "rg penguin zoo-project"
    ]
  },
  {
    "name": "Ripgrep fish in animals",
    "commands": [
      "rg fish zoo-project/animals"
    ]
  },
  {
    "name": "Recursive ripgrep reptile",
    "commands": [
      "rg reptile zoo-project"
    ]
  },
  {
    "name": "Ripgrep with less",
    "commands": [
      "rg ocean zoo-project | less"
    ]
  },
  {
    "name": "FZF recursive",
    "commands": [
      "fzf"
    ]
  },
  {
    "name": "Pipe ls into fzf",
    "commands": [
      "ls zoo-project/animals | fzf"
    ]
  },
  {
    "name": "Find txt files with fzf",
    "commands": [
      "find zoo-project -name \"*.txt\" | fzf"
    ]
  },
  {
    "name": "Open selected file in nvim",
    "commands": [
      "nvim $(find zoo-project -name \"*.txt\" | fzf)"
    ]
  },
  {
    "name": "Open selected file in nano",
    "commands": [
      "nano $(find zoo-project -name \"*.txt\" | fzf)"
    ]
  }
]
