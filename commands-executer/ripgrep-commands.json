[
  {
    "name": "Search Carnivore in all files",
    "commands": ["rg Carnivore"]
  },
  {
    "name": "Search Lion or Tiger with regex",
    "commands": ["rg 'Lion|Tiger'"]
  },
  {
    "name": "Case-insensitive search for lion",
    "commands": ["rg -i lion"]
  },
  {
    "name": "Show files containing Carnivore",
    "commands": ["rg -l Carnivore"]
  },
  {
    "name": "Show files not containing Carnivore",
    "commands": ["rg --files-without-match Carnivore"]
  },
  {
    "name": "Count Carnivore matches per file",
    "commands": ["rg -c Carnivore"]
  },
  {
    "name": "Count total Carnivore matches",
    "commands": ["rg -o Carnivore | wc -l"]
  },
  {
    "name": "Search Carnivore only in mammals",
    "commands": ["rg Carnivore mammals"]
  },
  {
    "name": "Search Omnivore only in birds",
    "commands": ["rg Omnivore birds"]
  },
  {
    "name": "Find all Name fields",
    "commands": ["rg '^Name:' "]
  },
  {
    "name": "Find habitats ending with Forest",
    "commands": ["rg 'Forest$'"]
  },
  {
    "name": "Find numbers in files",
    "commands": ["rg '\\\\\\\\d+' "]
  },
  {
    "name": "Find lifespan ranges",
    "commands": ["rg '\\\\\\\\d+-\\\\\\\\d+ years' "]
  },
  {
    "name": "Match whole word Bird",
    "commands": ["rg -w Bird "]
  },
  {
    "name": "Show 2 lines after Tiger",
    "commands": ["rg -A 2 Tiger "]
  },
  {
    "name": "Show 2 lines before Fact in lion file",
    "commands": ["rg -B 2 'Fact:' mammals/lion.txt"]
  },
  {
    "name": "Show 2 lines around Weight",
    "commands": ["rg -C 2 Weight "]
  },
  {
    "name": "Find files containing Herbivore",
    "commands": ["rg -l Herbivore"]
  },
  {
    "name": "Search only txt files",
    "commands": ["rg Carnivore -g '*.txt' "]
  },
  {
    "name": "Search only mammals txt files",
    "commands": ["rg Carnivore -g 'mammals/*.txt' "]
  },
  {
    "name": "Exclude reptiles directory",
    "commands": ["rg Carnivore -g '!reptiles/*' "]
  },
  {
    "name": "Search Omnivore without line numbers",
    "commands": ["rg -N Omnivore"]
  },
  {
    "name": "Extract diet values",
    "commands": ["rg -o 'Carnivore|Herbivore|Omnivore' "]
  },
  {
    "name": "Search hidden files too",
    "commands": ["rg Carnivore --hidden"]
  },
  {
    "name": "Search hidden and ignored files",
    "commands": ["rg Carnivore -uu"]
  },
  {
    "name": "Search binary files as text",
    "commands": ["rg -a Carnivore "]
  },
  {
    "name": "Literal search for speed value",
    "commands": ["rg -F 'Up to 80 km/h' "]
  },
  {
    "name": "Invert match Mammal in lion file",
    "commands": ["rg -v Mammal mammals/lion.txt"]
  },
  {
    "name": "Show ripgrep statistics",
    "commands": ["rg Carnivore --stats"]
  },
  {
    "name": "Output matches as JSON",
    "commands": ["rg Carnivore --json"]
  },
  {
    "name": "Find all habitats",
    "commands": ["rg '^Habitat:' "]
  },
  {
    "name": "Find all birds",
    "commands": ["rg '^Category: Bird' "]
  },

  {
    "name": "Find all omnivores",
    "commands": ["rg '^Diet: Omnivore' "]
  },
  {
    "name": "Find long-lived animals",
    "commands": ["rg '5[0-9]|[6-9][0-9]|100' "]
  },
  {
    "name": "Find all facts",
    "commands": ["rg '^Fact:' "]
  },
  {
    "name": "Find swimming animals",
    "commands": ["rg -i swim "]
  },
  {
    "name": "Show Carnivore with context",
    "commands": ["rg Carnivore  -C 1"]
  },
  {
    "name": "Find omnivore birds",
    "commands": ["rg '^Diet: Omnivore' birds"]
  },
  {
    "name": "Show files containing Fact",
    "commands": ["rg -l '^Fact:' "]
  },
  {
    "name": "Count carnivores",
    "commands": ["rg '^Diet: Carnivore' | wc -l"]
  },
  {
    "name": "Fuzzy select ripgrep result",
    "commands": ["rg Carnivore | fzf", "tiger"]
  },
  {
    "name": "Search Category then fuzzy filter",
    "commands": ["rg Category | fzf", "Bird"]
  },
  {
    "name": "Select file with rg and open in nvim",
    "commands": ["rg -l Carnivore | fzf | xargs nvim", "lion", ":q"]
  },
  {
    "name": "Find files mentioning swimmers",
    "commands": ["rg -l swimmer "]
  },
  {
    "name": "List only matching text for habitats",
    "commands": ["rg -o '(Savanna|Forest|Grassland)' "]
  },
  {
    "name": "Search multiple diets",
    "commands": ["rg 'Carnivore|Omnivore' "]
  },
  {
    "name": "Search exact Category lines",
    "commands": ["rg '^Category:' "]
  },
  {
    "name": "Search all files and show filenames only",
    "commands": ["rg -l . "]
  },
  {
    "name": "Show first match only per file",
    "commands": ["rg -m 1 Diet "]
  },
  {
    "name": "Count files containing Carnivore",
    "commands": ["rg -l Carnivore | wc -l"]
  },
  {
    "name": "Search for years",
    "commands": ["rg 'years' "]
  },
  {
    "name": "Find animals with exceptional abilities",
    "commands": ["rg 'Vision|Ability|Movement' "]
  },
  {
    "name": "Search for shell protection",
    "commands": ["rg shell "]
  },
  {
    "name": "Search and page results",
    "commands": ["rg Diet  | less", "q"]
  }
  ]
